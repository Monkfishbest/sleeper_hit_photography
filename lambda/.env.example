# Google Drive API Credentials (for Lambda sync function)
# Get these from Google Cloud Console service account JSON
GOOGLE_DRIVE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_DRIVE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n

# Google Drive Folder IDs (one for each photo category)
# Get folder IDs from the URL when viewing the folder
GOOGLE_DRIVE_EVENTS_FOLDER_ID=
GOOGLE_DRIVE_LANDSCAPES_FOLDER_ID=
GOOGLE_DRIVE_STREET_FOLDER_ID=
GOOGLE_DRIVE_PORTRAITS_FOLDER_ID=

# AWS S3 Configuration
S3_BUCKET_NAME=sleeper-hit-photography-images
AWS_REGION=us-east-1
